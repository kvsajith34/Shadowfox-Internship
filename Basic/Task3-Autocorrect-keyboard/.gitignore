# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# ── Virtual environments ───────────────────────────────────────────────────────
venv/
.venv/
env/
.env/
ENV/

# ── Distribution / packaging ───────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg
.eggs/
MANIFEST

# ── Testing & coverage ─────────────────────────────────────────────────────────
.pytest_cache/
.coverage
coverage.xml
htmlcov/
*.log

# ── Streamlit ──────────────────────────────────────────────────────────────────
.streamlit/secrets.toml

# ── Environment variables ──────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── IDEs & editors ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Jupyter (if notebooks are added later) ─────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Model / data artifacts ─────────────────────────────────────────────────────
*.pkl
*.pickle
*.h5
*.model

# ── Outputs (keep the folder, ignore generated files) ─────────────────────────
outputs/*
!outputs/.gitkeep
