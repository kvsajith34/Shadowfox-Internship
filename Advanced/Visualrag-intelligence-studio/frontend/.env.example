# VisualRAG Intelligence Studio — Frontend Environment Variables
# Copy this file to .env before running npm run dev.

# ── Local development (Vite proxy mode) ──────────────────────────────────────
# Leave VITE_API_BASE_URL empty.
# All /api/* calls become relative URLs and are proxied by the Vite dev server
# to http://localhost:8000 on the server side.
# This means the Vite network URL (http://192.168.x.x:5173) also works because
# the proxy runs on the server, not in the browser.
VITE_API_BASE_URL=

# ── Deployed frontend (Render / Railway / Vercel / Netlify) ──────────────────
# Set this to your deployed backend's absolute URL.
# VITE_API_BASE_URL=https://your-backend.onrender.com

# ── LAN note ─────────────────────────────────────────────────────────────────
# If you run the backend with --host 0.0.0.0 and need to hit it directly from
# a different machine (no Vite proxy), set:
# VITE_API_BASE_URL=http://<your-machine-ip>:8000
# and add http://<your-machine-ip>:5173 to CORS_ORIGINS in backend/.env.
