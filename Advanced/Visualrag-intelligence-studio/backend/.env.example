# VisualRAG Intelligence Studio - Backend .env

APP_NAME=VisualRAG Intelligence Studio
APP_ENV=development
MOCK_MODE=true
DEFAULT_PROVIDER=mock
OPENAI_API_KEY=
GOOGLE_API_KEY=
HF_TOKEN=
CLAUDE_API_KEY=
# Optional alias env var names — used only as a fallback when the primary
# name above is empty. You only need ONE of GOOGLE_API_KEY / GEMINI_API_KEY,
# and ONE of HF_TOKEN / HUGGINGFACE_API_KEY / HUGGINGFACE_TOKEN.
# GEMINI_API_KEY=
# HUGGINGFACE_API_KEY=
# HUGGINGFACE_TOKEN=
OPENAI_MODEL=gpt-4o-mini
GEMINI_MODEL=gemini-2.5-flash
HF_MODEL=Qwen/Qwen2.5-VL-3B-Instruct
# If GEMINI_MODEL returns "NotFound" (model name unavailable for your API
# version/region), the backend automatically retries this fixed list in
# order and logs which one succeeded — no .env change needed for that case:
#   gemini-2.5-flash -> gemini-2.5-flash-lite -> gemini-2.0-flash
CLAUDE_MODEL=claude-sonnet-4-20250514
DATABASE_URL=sqlite:///./visualrag.db
POSTGRES_USER=visualrag
POSTGRES_PASSWORD=visualrag_password
POSTGRES_DB=visualrag_db
CHROMA_DIR=./chroma_db
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=50
STORAGE_BACKEND=local
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=visualrag
S3_SECRET_KEY=visualrag_password
S3_BUCKET=visualrag-uploads
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://127.0.0.1:3000","http://127.0.0.1:5173"]
# LAN / network URL access: add your machine's LAN IP, e.g.:
# CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://192.168.1.42:5173"]

# ── Notes ──────────────────────────────────────────────────────────────────
# This .env is loaded reliably from the backend/ directory regardless of
# which directory `uvicorn` is started from.
# To check exactly why the app is or isn't using a real provider, visit:
#   GET /api/v1/provider-debug
# It returns only booleans/short strings — never actual key values.
